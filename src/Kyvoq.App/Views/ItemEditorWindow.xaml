<ui:FluentWindow x:Class="Kyvoq.App.Views.ItemEditorWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:controls="clr-namespace:Kyvoq.App.Controls"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="启动项目"
                 Width="680"
                 Height="700"
                 MinWidth="600"
                 MinHeight="560"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="CanResize"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 ShowInTaskbar="False">
    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="68" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="{Binding Title, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                     ShowMaximize="False"
                     ShowMinimize="False" />

        <ScrollViewer Grid.Row="1"
                      Margin="24,10,16,0"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,8,16">
                <Border Padding="16"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="84" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="104" />
                        </Grid.ColumnDefinitions>

                        <Border Width="72"
                                Height="72"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Background="{DynamicResource SelectedBackgroundBrush}"
                                CornerRadius="20">
                            <Grid>
                                <TextBlock x:Name="InitialText"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}"
                                           Text="R" />
                                <Image x:Name="IconPreview"
                                       Width="50"
                                       Height="50"
                                       Stretch="Uniform" />
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="启动项目" />
                            <TextBlock x:Name="TypeText"
                                       Margin="0,5,12,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="12"
                                       Text="程序" />
                            <TextBlock Margin="0,5,12,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Text="图标默认从启动目标读取"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <Button Height="34"
                                    MinWidth="0"
                                    Margin="0,0,0,6"
                                    Padding="10,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="修改图标"
                                    Click="BrowseIcon_Click" />
                            <Button Height="34"
                                    MinWidth="0"
                                    Padding="10,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="默认图标"
                                    Click="ClearIcon_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock Margin="2,16,0,6" Text="名称" />
                <TextBox x:Name="NameTextBox"
                         MinHeight="38"
                         TextChanged="NameTextBox_TextChanged" />

                <TextBlock Margin="2,14,0,6" Text="目标" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="88" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TargetTextBox"
                             MinHeight="38"
                             Margin="0,0,8,0"
                             TextChanged="TargetTextBox_TextChanged"
                             LostKeyboardFocus="TargetTextBox_LostKeyboardFocus" />
                    <Button Grid.Column="1"
                            MinWidth="0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="浏览"
                            Click="BrowseTarget_Click" />
                </Grid>

                <StackPanel x:Name="ProgramOptionsPanel">
                    <TextBlock Margin="2,14,0,6" Text="启动参数" />
                    <TextBox x:Name="ArgumentsTextBox"
                             Height="62"
                             Padding="10,8"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top" />

                    <Grid Margin="2,14,0,6">
                        <TextBlock VerticalAlignment="Center" Text="环境变量" />
                        <Button x:Name="AddEnvironmentVariableButton"
                                Width="108"
                                Height="32"
                                MinWidth="0"
                                Padding="8,0"
                                HorizontalAlignment="Right"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="＋ 添加变量"
                                Click="AddEnvironmentVariable_Click" />
                    </Grid>
                    <TextBlock Margin="2,0,0,7"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11"
                               Text="继承系统环境；同名变量由下方值覆盖，值按原样传递。" />
                    <Border Padding="10,10,8,2"
                            Background="{DynamicResource CardBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid Margin="2,0,38,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5*" />
                                    <ColumnDefinition Width="7*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           Text="变量名" />
                                <TextBlock Grid.Column="1"
                                           Margin="8,0,0,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           Text="值" />
                            </Grid>
                            <ItemsControl x:Name="EnvironmentVariablesList" Grid.Row="1">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="5*" />
                                                <ColumnDefinition Width="7*" />
                                                <ColumnDefinition Width="36" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox MinHeight="34"
                                                     Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBox Grid.Column="1"
                                                     MinHeight="34"
                                                     Margin="8,0,8,0"
                                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Grid.Column="2"
                                                    Width="32"
                                                    Height="32"
                                                    MinWidth="0"
                                                    Padding="0"
                                                    Style="{StaticResource IconButtonStyle}"
                                                    ToolTip="删除环境变量"
                                                    CommandParameter="{Binding}"
                                                    Click="DeleteEnvironmentVariable_Click">
                                                <TextBlock FontFamily="Segoe Fluent Icons"
                                                           FontSize="13"
                                                           Text="&#xE74D;" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="EnvironmentEmptyText"
                                       Grid.Row="2"
                                       Margin="2,4,0,12"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Text="未设置环境变量" />
                        </Grid>
                    </Border>

                    <CheckBox x:Name="RunAsAdministratorCheckBox"
                              Margin="2,10,0,0"
                              Content="始终以管理员权限启动" />
                </StackPanel>

                <TextBlock Margin="2,14,0,6" Text="全局快捷键" />
                <controls:HotkeyBox x:Name="HotkeyInput"
                                    MinHeight="38"
                                    VerticalContentAlignment="Center" />
                <TextBlock x:Name="HotkeyHintText"
                           Margin="2,5,0,0"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="11"
                           Text="聚焦后按组合键；Backspace 清除" />
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="24,12,24,16">
            <TextBlock x:Name="ValidationText"
                       MaxWidth="390"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DangerBrush}"
                       TextWrapping="Wrap" />
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Content="取消"
                        Click="Cancel_Click" />
                <Button Style="{StaticResource PrimaryButtonStyle}"
                        Content="保存"
                        Click="Confirm_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
