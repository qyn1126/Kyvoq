<ui:FluentWindow x:Class="Kyvoq.App.Views.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Kyvoq 搜索"
        Width="640"
        Height="440"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ExtendsContentIntoTitleBar="True"
        ResizeMode="NoResize"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Border Background="{DynamicResource OverlayBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="18">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" Opacity="0.28" ShadowDepth="8" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="88" />
                <RowDefinition Height="*" />
                <RowDefinition Height="44" />
            </Grid.RowDefinitions>

            <Border Margin="22,20,22,12"
                    Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="82" />
                    </Grid.ColumnDefinitions>
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontFamily="Segoe Fluent Icons"
                               FontSize="21"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="&#xE721;" />
                    <TextBox x:Name="QueryTextBox"
                             Grid.Column="1"
                             FontSize="20"
                             Style="{StaticResource ChromeLessTextBoxStyle}"
                             TextChanged="QueryTextBox_TextChanged" />
                    <Border Grid.Column="2"
                            Margin="12"
                            Background="{DynamicResource SidebarBackgroundBrush}"
                            CornerRadius="7">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="11"
                                   Text="ESC 关闭" />
                    </Border>
                </Grid>
            </Border>

            <ListBox x:Name="ResultsListBox"
                     Grid.Row="1"
                     Margin="14,0"
                     ItemsSource="{Binding Results}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     PreviewMouseLeftButtonUp="ResultsListBox_PreviewMouseLeftButtonUp">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="8,3" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ResultBorder"
                                            Padding="14,10"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="12">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ResultBorder" Property="Background" Value="{DynamicResource CardHoverBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ResultBorder" Property="Background" Value="{DynamicResource SelectedBackgroundBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Height="50">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="58" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="46"
                                    Height="46"
                                    HorizontalAlignment="Left"
                                    Background="{DynamicResource CardBackgroundBrush}"
                                    CornerRadius="12">
                                <Grid>
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               Text="{Binding Initial}" />
                                    <Image Width="32" Height="32" Source="{Binding ItemViewModel.Icon}" Stretch="Uniform" />
                                </Grid>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding Name}" />
                                <TextBlock Margin="0,3,0,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           TextTrimming="CharacterEllipsis">
                                    <Run Text="{Binding GroupName, Mode=OneWay}" />
                                    <Run Text="  ·  " />
                                    <Run Text="{Binding Target, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                            <Border Grid.Column="2"
                                    Margin="12,8,0,8"
                                    Padding="10,0"
                                    Background="{DynamicResource SidebarBackgroundBrush}"
                                    CornerRadius="7">
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           Text="{Binding HotkeyText}" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Row="1" IsHitTestVisible="False">
                <TextBlock x:Name="EmptyText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="15"
                           Text="没有匹配的启动项目"
                           Visibility="Collapsed" />
            </Grid>

            <Grid Grid.Row="2" Margin="28,0">
                <TextBlock VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="11"
                           Text="↑↓ 选择    Enter 启动" />
                <TextBlock HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="11"
                           Text="Kyvoq · 快速抵达" />
            </Grid>
        </Grid>
    </Border>
</ui:FluentWindow>
