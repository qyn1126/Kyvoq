<ui:FluentWindow x:Class="Kyvoq.App.Views.TextInputDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="输入"
                 Width="400"
                 Height="210"
                 MinWidth="400"
                 MinHeight="210"
                 WindowStartupLocation="CenterOwner"
                 WindowStyle="None"
                 ResizeMode="NoResize"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 Background="Transparent"
                 ShowInTaskbar="False">
    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="58" />
            <RowDefinition Height="*" />
            <RowDefinition Height="68" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <TextBlock x:Name="TitleText"
                       Margin="22,0"
                       VerticalAlignment="Center"
                       FontSize="17"
                       FontWeight="SemiBold" />
            <Button HorizontalAlignment="Right"
                    Margin="0,10,12,10"
                    Style="{StaticResource IconButtonStyle}"
                    Click="Cancel_Click">
                <TextBlock FontFamily="Segoe Fluent Icons" FontSize="14" Text="&#xE8BB;" />
            </Button>
        </Grid>

        <StackPanel Grid.Row="1" Margin="22,8,22,0">
            <TextBlock x:Name="PromptText" Margin="2,0,0,8" Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBox x:Name="ValueTextBox"
                     MinHeight="36"
                     VerticalContentAlignment="Center"
                     KeyDown="ValueTextBox_KeyDown" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Margin="22,10,22,16"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Margin="0,0,10,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Content="取消"
                    Click="Cancel_Click" />
            <Button Style="{StaticResource PrimaryButtonStyle}"
                    Content="确定"
                    Click="Confirm_Click" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
