<Window x:Class="Kyvoq.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Kyvoq.App.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Kyvoq"
        Width="920"
        Height="620"
        MinWidth="100"
        MinHeight="100"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        PreviewKeyDown="Window_PreviewKeyDown">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <ItemsPanelTemplate x:Key="NormalItemsPanelTemplate">
            <ui:VirtualizingWrapPanel ItemSize="104,112" SpacingMode="None" />
        </ItemsPanelTemplate>

        <ItemsPanelTemplate x:Key="CompactItemsPanelTemplate">
            <ui:VirtualizingWrapPanel ItemSize="72,76" SpacingMode="None" />
        </ItemsPanelTemplate>

        <ItemsPanelTemplate x:Key="TinyItemsPanelTemplate">
            <ui:VirtualizingWrapPanel ItemSize="52,56" SpacingMode="None" />
        </ItemsPanelTemplate>

        <Style x:Key="PinToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="PinBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PinBorder" Property="Background" Value="{DynamicResource CardHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="PinBorder" Property="Background" Value="{DynamicResource SelectedBackgroundBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PinBorder" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="GroupTemplate">
            <Border Padding="4,10"
                    ClipToBounds="True"
                    AllowDrop="True"
                    Tag="{Binding}"
                    ContextMenuOpening="Group_ContextMenuOpening"
                    DragEnter="Group_DragEnter"
                    Drop="Group_Drop">
                <Border.ContextMenu>
                    <ContextMenu MinWidth="180" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <ui:MenuItem Header="重命名" Icon="{ui:SymbolIcon Rename24}" CommandParameter="{Binding}" Click="RenameGroup_Click" />
                        <ui:MenuItem Header="上移" Icon="{ui:SymbolIcon ArrowUp24}" CommandParameter="{Binding}" Click="MoveGroupUp_Click" />
                        <ui:MenuItem Header="下移" Icon="{ui:SymbolIcon ArrowDown24}" CommandParameter="{Binding}" Click="MoveGroupDown_Click" />
                        <Separator />
                        <ui:MenuItem Header="删除分组" Icon="{ui:SymbolIcon Delete24}" CommandParameter="{Binding}" Click="DeleteGroup_Click" />
                    </ContextMenu>
                </Border.ContextMenu>
                <TextBlock HorizontalAlignment="Stretch"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Text="{Binding Name}"
                           TextAlignment="Center"
                           ToolTip="{Binding Name}" />
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="CompactItemTemplate">
            <Grid Margin="1" ClipToBounds="True" ToolTip="{Binding Name}">
                <Grid.ContextMenu>
                    <ContextMenu MinWidth="220" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <ui:MenuItem Header="启动" Icon="{ui:SymbolIcon Play24}" CommandParameter="{Binding}" Click="LaunchItem_Click" />
                        <ui:MenuItem Header="以管理员身份启动" Icon="{ui:SymbolIcon Shield24}" CommandParameter="{Binding}" Click="LaunchItemAsAdministrator_Click" />
                        <Separator />
                        <ui:MenuItem Header="打开所在位置" Icon="{ui:SymbolIcon FolderOpen24}" CommandParameter="{Binding}" Click="OpenItemLocation_Click" />
                        <ui:MenuItem Header="复制目标路径" Icon="{ui:SymbolIcon Copy24}" CommandParameter="{Binding}" Click="CopyItemTarget_Click" />
                        <Separator />
                        <ui:MenuItem Header="编辑" Icon="{ui:SymbolIcon Edit24}" CommandParameter="{Binding}" Click="EditItem_Click" />
                        <ui:MenuItem Header="删除" Icon="{ui:SymbolIcon Delete24}" CommandParameter="{Binding}" Click="DeleteItem_Click" />
                    </ContextMenu>
                </Grid.ContextMenu>
                <Border x:Name="CompactIconFrame"
                        Width="40"
                        Height="40"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        CornerRadius="12">
                    <Grid>
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Text="{Binding Initial}" />
                        <Image Width="30" Height="30" Source="{Binding Icon}" Stretch="Uniform" />
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid ClipToBounds="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="196" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="SidebarPanel"
                    Grid.Column="0"
                    Background="{DynamicResource SidebarBackgroundBrush}"
                    CornerRadius="14,0,0,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition x:Name="SidebarFooterRow" Height="78" />
                    </Grid.RowDefinitions>

                    <ListBox x:Name="GroupsListBox"
                             Grid.Row="0"
                             Margin="12,10,10,0"
                             ItemsSource="{Binding Groups}"
                             ItemTemplate="{StaticResource GroupTemplate}"
                             SelectedItem="{Binding SelectedGroup}"
                             Background="Transparent"
                             BorderThickness="0"
                             FocusVisualStyle="{x:Null}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Margin" Value="0,3" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <EventSetter Event="MouseEnter" Handler="Group_MouseEnter" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="GroupSelectionBorder"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="11">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="GroupSelectionBorder" Property="Background" Value="{DynamicResource CardHoverBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="GroupSelectionBorder" Property="Background" Value="{DynamicResource SelectedBackgroundBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <Grid x:Name="SidebarFooter" Grid.Row="1" Margin="12,10,10,16">
                        <Button x:Name="AddGroupButton"
                                Height="38"
                                MinWidth="0"
                                Padding="0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Style="{StaticResource SecondaryButtonStyle}"
                                ToolTip="新建分组"
                                Click="AddGroup_Click">
                            <TextBlock x:Name="AddGroupIcon"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="16"
                                       Text="&#xE710;" />
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <Grid x:Name="ContentPanel" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="HeaderRow" Height="62" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid x:Name="HeaderGrid" Grid.Row="0" Margin="20,0,10,0" Background="Transparent" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="SearchColumn" Width="38" />
                        <ColumnDefinition x:Name="PinColumn" Width="38" />
                        <ColumnDefinition x:Name="MoreColumn" Width="38" />
                        <ColumnDefinition x:Name="CloseColumn" Width="38" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="SearchAllButton"
                            Grid.Column="1"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="搜索全部项目"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="OpenSearch_Click">
                        <TextBlock FontFamily="Segoe Fluent Icons" FontSize="16" Text="&#xE11A;" />
                    </Button>
                    <ToggleButton x:Name="PinButton"
                                  Grid.Column="2"
                                  Style="{StaticResource PinToggleButtonStyle}"
                                  ToolTip="固定面板"
                                  AutomationProperties.Name="固定面板"
                                  shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                  Click="PinButton_Click">
                        <TextBlock x:Name="PinIcon"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="15"
                                   Text="&#xE718;" />
                    </ToggleButton>
                    <Button x:Name="MoreButton"
                            Grid.Column="3"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="更多"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="MoreButton_Click">
                        <TextBlock FontFamily="Segoe Fluent Icons" FontSize="17" Text="&#xE712;" />
                        <Button.ContextMenu>
                            <ContextMenu MinWidth="180">
                                <ui:MenuItem Header="导入配置…" Icon="{ui:SymbolIcon ArrowDownload24}" Click="ImportConfiguration_Click" />
                                <ui:MenuItem Header="导出配置…" Icon="{ui:SymbolIcon ArrowUpload24}" Click="ExportConfiguration_Click" />
                                <ui:MenuItem Header="添加项目…" Icon="{ui:SymbolIcon Add24}" Click="AddItem_Click" />
                                <Separator />
                                <ui:MenuItem Header="打开数据目录" Icon="{ui:SymbolIcon FolderOpen24}" Click="OpenDataDirectory_Click" />
                                <ui:MenuItem Header="设置" Icon="{ui:SymbolIcon Settings24}" Click="Settings_Click" />
                                <Separator />
                                <ui:MenuItem Header="退出 Kyvoq" Icon="{ui:SymbolIcon Power24}" Click="Exit_Click" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button x:Name="CloseButton"
                            Grid.Column="4"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="隐藏到托盘"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="Close_Click">
                        <TextBlock FontFamily="Segoe Fluent Icons" FontSize="14" Text="&#xE8BB;" />
                    </Button>
                </Grid>

                <Grid x:Name="ItemsHost" Grid.Row="1" Margin="12,2,10,10">
                    <ListBox x:Name="ItemsListBox"
                             ItemsSource="{Binding VisibleItems}"
                             ItemsPanel="{StaticResource NormalItemsPanelTemplate}"
                             Background="Transparent"
                             BorderThickness="0"
                             FocusVisualStyle="{x:Null}"
                             AllowDrop="True"
                             ScrollViewer.CanContentScroll="True"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             DragEnter="ItemsListBox_DragEnter"
                             Drop="ItemsListBox_Drop">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Margin" Value="0,0,1,1" />
                                <Setter Property="AllowDrop" Value="True" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="TileSelectionBorder"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="15">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="TileSelectionBorder" Property="Background" Value="{DynamicResource ItemHoverBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="Item_PreviewMouseLeftButtonDown" />
                                <EventSetter Event="PreviewMouseMove" Handler="Item_PreviewMouseMove" />
                                <EventSetter Event="PreviewMouseLeftButtonUp" Handler="Item_PreviewMouseLeftButtonUp" />
                                <EventSetter Event="DragEnter" Handler="Item_DragEnter" />
                                <EventSetter Event="Drop" Handler="Item_Drop" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4" ClipToBounds="True">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="58" />
                                        <RowDefinition Height="30" />
                                        <RowDefinition Height="14" />
                                    </Grid.RowDefinitions>
                                    <Grid.ContextMenu>
                                        <ContextMenu MinWidth="220" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <ui:MenuItem Header="启动" Icon="{ui:SymbolIcon Play24}" CommandParameter="{Binding}" Click="LaunchItem_Click" />
                                            <ui:MenuItem Header="以管理员身份启动" Icon="{ui:SymbolIcon Shield24}" CommandParameter="{Binding}" Click="LaunchItemAsAdministrator_Click" />
                                            <Separator />
                                            <ui:MenuItem Header="打开所在位置" Icon="{ui:SymbolIcon FolderOpen24}" CommandParameter="{Binding}" Click="OpenItemLocation_Click" />
                                            <ui:MenuItem Header="复制目标路径" Icon="{ui:SymbolIcon Copy24}" CommandParameter="{Binding}" Click="CopyItemTarget_Click" />
                                            <Separator />
                                            <ui:MenuItem Header="编辑" Icon="{ui:SymbolIcon Edit24}" CommandParameter="{Binding}" Click="EditItem_Click" />
                                            <ui:MenuItem Header="删除" Icon="{ui:SymbolIcon Delete24}" CommandParameter="{Binding}" Click="DeleteItem_Click" />
                                        </ContextMenu>
                                    </Grid.ContextMenu>

                                    <Border x:Name="FullIconFrame"
                                            Width="56"
                                            Height="56"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            CornerRadius="16">
                                        <Grid>
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       Text="{Binding Initial}" />
                                            <Image Width="40" Height="40" Source="{Binding Icon}" Stretch="Uniform" />
                                        </Grid>
                                    </Border>
                                    <TextBlock Grid.Row="1"
                                               Margin="2,0"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               LineHeight="14"
                                               Text="{Binding DisplayName}"
                                               TextAlignment="Center"
                                               TextTrimming="None"
                                               TextWrapping="Wrap"
                                               Width="92"
                                               ToolTip="{Binding Target}" />
                                    <Grid Grid.Row="2">
                                        <TextBlock HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="9"
                                                   Text="{Binding HotkeyText}" />
                                        <Border x:Name="ConflictBadge"
                                                Width="18"
                                                Height="18"
                                                HorizontalAlignment="Right"
                                                Background="{DynamicResource DangerBrush}"
                                                CornerRadius="9"
                                                ToolTip="快捷键冲突，项目仍可手动启动"
                                                Visibility="Collapsed">
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       Foreground="White"
                                                       Text="!" />
                                        </Border>
                                    </Grid>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding HasHotkeyConflict}" Value="True">
                                        <Setter TargetName="ConflictBadge" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>

            <ui:SnackbarPresenter x:Name="DeletionSnackbarPresenter"
                                  Grid.ColumnSpan="2"
                                  Margin="12"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Bottom"
                                  Panel.ZIndex="20" />
        </Grid>
    </Grid>
</Window>
